# ============================================================
# spec-ai-writer 環境変数サンプル
# Web UI の「設定」ページからも変更できます。
# UI で保存した値は data/settings.json に書き込まれ、
# 環境変数より優先して適用されます。
# ============================================================

# ----- アクティブプロバイダ -----
# claude / openai / openrouter / ollama / lmstudio / kimi / bedrock
DEFAULT_LLM_PROVIDER=claude

# ----- Claude (Anthropic API) -----
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ----- OpenAI -----
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5-mini

# ----- OpenRouter -----
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

# ----- Ollama (ローカル LLM) -----
OLLAMA_MODEL=gemma3:4b
OLLAMA_BASE_URL=              # 空欄 = http://localhost:11434/v1

# ----- LM Studio (ローカル LLM) -----
LMSTUDIO_MODEL=google/gemma-3-4b
LMSTUDIO_BASE_URL=            # 空欄 = http://localhost:1234/v1

# ----- Moonshot Kimi -----
KIMI_API_KEY=your_kimi_api_key_here
KIMI_MODEL=kimi-k2.6

# ----- AWS Bedrock -----
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=ap-northeast-1
BEDROCK_MODEL_ID=global.anthropic.claude-haiku-4-5-20251001-v1:0

# ----- 生成パラメータ -----
TEMPERATURE=0.7

# ----- アプリ設定 -----
DATA_DIR=./data
AUTO_GIT_COMMIT=true

# アプリケーション環境 (development または production)
# production: バックエンドが frontend/dist を直接サーブ
# development: Vite 開発サーバーを別途起動（デフォルト）
APP_ENV=development
